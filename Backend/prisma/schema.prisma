model Purchase {
  id                           Int              @id @default(autoincrement())
  purchase_code                String?          @unique
  purchase_category            PurchaseCategory @default(SINGLE)
  type                         PurchaseType     @default(PLOT)
  sl_no                        String?
  location                     String?
  purchase_broker_name         String?
  purchase_broker_details      String?          @db.Text
  sell_broker_name             String?
  sell_broker_details          String?          @db.Text
  seller_details               String?          @db.Text
  plot_no                      String?
  purchased_area               Decimal?         @db.Decimal(10, 2)
  purchased_area_details       String?
  rate                         Decimal?         @db.Decimal(10, 2)
  rate_details                 String?
  total_amount_details         String?
  advance_paid                 Decimal?         @db.Decimal(10, 2)
  advance_payment_details      String?          @db.Text
  instalment_details           String?          @db.Text
  remaining_paid               Boolean          @default(false)
  against_registration_paid    Boolean          @default(false)
  against_registration_amount  Decimal?         @db.Decimal(10, 2)
  against_registration_received Boolean         @default(false)
  against_registration_received_date DateTime?
  registration_date            DateTime?
  registration_details         String?          @db.Text
  brokerage                    Decimal?         @db.Decimal(10, 2)
  brokerage_details            String?
  extra_expenses               Decimal?         @db.Decimal(10, 2)
  extra_expenses_details       String?
  registration_charges         Decimal?         @db.Decimal(10, 2)
  registration_charges_details String?
  extra_income                 Decimal?         @db.Decimal(10, 2)
  extra_income_details         String?
  other_details                String?          @db.Text
  status                       PurchaseStatus   @default(ACTIVE)
  created_at                   DateTime         @default(now())
  updated_at                   DateTime         @updatedAt
  inventory                    Inventory[]
  purchaseInstallment          PurchaseInstallment?
}

model Project {
  id           Int           @id @default(autoincrement())
  project_code String?       @unique
  name         String
  location     String?
  status       ProjectStatus @default(OPEN)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  inventory    Inventory[]
}

enum ProjectStatus {
  OPEN
  ONGOING
  CLOSED
}

model Inventory {
  id                Int             @id @default(autoincrement())
  inventory_code    String?         @unique
  purchase_id       Int
  project_id        Int?
  type              UnitType        @default(PLOT)
  sl_no             String?
  location          String?
  plot_no           String?
  front_area        Decimal?        @db.Decimal(10, 4)
  front_area_details String?
  back_area         Decimal?        @db.Decimal(10, 4)
  back_area_details  String?
  area              Decimal?        @db.Decimal(10, 4)
  area_unit         String?
  rate              Decimal?        @db.Decimal(10, 2)
  registration_date DateTime?
  status            InventoryStatus @default(AVAILABLE)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  purchase          Purchase        @relation(fields: [purchase_id], references: [id])
  project           Project?        @relation(fields: [project_id], references: [id])
  sales             Sale[]
}

enum PurchaseCategory {
  SINGLE
  DIVIDED
}

enum PurchaseType {
  LAND
  SHOP
  PLOT
}

enum PurchaseStatus {
  ACTIVE
  INACTIVE
}

enum UnitType {
  PLOT
  SHOP
  LAND
}

enum InventoryStatus {
  AVAILABLE
  RESERVED
  SOLD
  REGISTERED
}

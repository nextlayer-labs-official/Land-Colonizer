  inst_13_paid    Boolean   @default(false)
  inst_14_amount  Decimal?  @db.Decimal(12, 2)
  inst_14_date    DateTime?
  inst_14_paid    Boolean   @default(false)
  inst_15_amount  Decimal?  @db.Decimal(12, 2)
  inst_15_date    DateTime?
  inst_15_paid    Boolean   @default(false)
  inst_16_amount  Decimal?  @db.Decimal(12, 2)
  inst_16_date    DateTime?
  inst_16_paid    Boolean   @default(false)
  inst_17_amount  Decimal?  @db.Decimal(12, 2)

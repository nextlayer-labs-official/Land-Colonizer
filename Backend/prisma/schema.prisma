generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  slug            String           @unique
  description     String?
  is_system       Boolean          @default(false)
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  users           User[]
  rolePermissions RolePermission[]
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  phone               String?              @unique
  password            String
  role                Role                 @relation(fields: [role_id], references: [id])
  role_id             Int
  status              UserStatus           @default(ACTIVE)
  is_verified         Boolean              @default(false)
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt
  passwordResetTokens PasswordResetToken[]
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Module {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  slug        String       @unique
  description String?
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  permissions Permission[]
}

model Permission {
  id              Int              @id @default(autoincrement())
  module          Module           @relation(fields: [module_id], references: [id])
  module_id       Int
  action          PermissionAction
  code            String           @unique
  created_at      DateTime         @default(now())
  rolePermissions RolePermission[]

  @@unique([module_id, action])
}

enum PermissionAction {
  CREATE
  VIEW
  EDIT
  DELETE
  APPROVE
  FINANCE
}

model RolePermission {
  id            Int        @id @default(autoincrement())
  role          Role       @relation(fields: [role_id], references: [id])
  role_id       Int
  permission    Permission @relation(fields: [permission_id], references: [id])
  permission_id Int
  allowed       Boolean    @default(false)

  @@unique([role_id, permission_id])
}

model CompanySettings {
  id                   Int      @id @default(autoincrement())
  company_name         String   @default("AMS")
  company_logo         String?
  company_address      String?  @db.Text
  company_phone        String?
  company_email        String?
  company_website      String?
  company_gstin        String?
  smtp_host            String?
  smtp_port            Int      @default(587)
  smtp_user            String?
  smtp_pass            String?
  smtp_from_name       String?
  smtp_from_email      String?
  email_notifications  Boolean  @default(false)
  login_max_attempts   Int      @default(5)
  login_window_minutes Int      @default(15)
  max_upload_mb        Int      @default(5)
  project_prefix       String   @default("PRJ")
  purchase_prefix      String   @default("PUR")
  inventory_prefix     String   @default("INV")
  sale_prefix          String   @default("SAL")
  customer_prefix      String   @default("CUS")
  broker_prefix        String   @default("BRK")
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
}

model Customer {
  id            Int            @id @default(autoincrement())
  customer_code String?        @unique
  name          String
  phone         String?
  email         String?
  address       String?        @db.Text
  type          CustomerType   @default(INDIVIDUAL)
  pan           String?
  aadhaar       String?
  other         String?
  status        CustomerStatus @default(ACTIVE)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  sales         Sale[]
  bookings      SaleBooking[]
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

model Broker {
  id          Int          @id @default(autoincrement())
  broker_code String?      @unique
  name        String
  phone       String?
  email       String?
  details     String?      @db.Text
  status      BrokerStatus @default(ACTIVE)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  sales       Sale[]
}

enum BrokerStatus {
  ACTIVE
  INACTIVE
}

model Sale {
  id                        Int              @id @default(autoincrement())
  sale_code                 String?          @unique
  inventory_id              Int?
  customer_id               Int?
  broker_id                 Int?
  sale_date                 DateTime?
  type                      SaleType?
  sl_no                     String?
  details                   String?          @db.Text
  broker_name               String?
  broker_details            String?          @db.Text
  front_area                Decimal?         @db.Decimal(10, 2)
  front_area_details        String?
  back_area                 Decimal?         @db.Decimal(10, 2)
  back_area_details         String?
  total_area                Decimal?         @db.Decimal(10, 2)
  total_area_details        String?
  plot_rate                 Decimal?         @db.Decimal(10, 2)
  total_value               Decimal?         @db.Decimal(10, 2)
  selling_rate              Decimal?         @db.Decimal(10, 2)
  actual_price              Decimal?         @db.Decimal(10, 2)
  booking_amount            Decimal?         @db.Decimal(10, 2)
  booking_details           String?          @db.Text
  advance_payment           Decimal?         @db.Decimal(10, 2)
  advance_payment_details   String?          @db.Text
  balance_amount            Decimal?         @db.Decimal(10, 2)
  balance_amount_details    String?
  registration_charges      Decimal?         @db.Decimal(10, 2)
  registration_details      String?          @db.Text
  intkaal_charges           Decimal?         @db.Decimal(10, 2)
  intkaal_details           String?
  water_connection_charges  Decimal?         @db.Decimal(10, 2)
  water_connection_details  String?
  electricity_meter_charges Decimal?         @db.Decimal(10, 2)
  electricity_meter_details String?
  payment_due_date          DateTime?
  registration_area         Decimal?         @db.Decimal(10, 2)
  discount                  Decimal?         @db.Decimal(10, 2)
  discount_details          String?
  brokerage                 Decimal?         @db.Decimal(10, 2)
  brokerage_details         String?
  incentive                 Decimal?         @db.Decimal(10, 2)
  incentive_details         String?
  extra_income              Decimal?         @db.Decimal(10, 2)
  extra_income_details      String?
  net_amount                Decimal?         @db.Decimal(10, 2)
  intkaal_number            String?
  date_of_registration      DateTime?
  vasika                    String?
  possession                PossessionStatus @default(PENDING)
  possession_detail         String?
  other_details             String?          @db.Text
  status                    SaleStatus       @default(ACTIVE)
  sale_confirmed            Boolean          @default(false)
  created_at                DateTime         @default(now())
  updated_at                DateTime         @updatedAt
  inventory                 Inventory?       @relation(fields: [inventory_id], references: [id])
  customer                  Customer?        @relation(fields: [customer_id], references: [id])
  broker                    Broker?          @relation(fields: [broker_id], references: [id])
  installment               Installment?
  bookings                  SaleBooking[]
}

enum SaleType {
  PLOT
  SHOP
  SHOP_WIRE
  PLOT_WIRE
}

enum PossessionStatus {
  PENDING
  SYMBOLIC
  PHYSICAL
}

enum SaleStatus {
  ACTIVE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REFUNDED
}

model SaleBooking {
  id             Int           @id @default(autoincrement())
  sale_id        Int
  customer_id    Int?
  booking_amount Decimal?      @db.Decimal(10, 2)
  notes          String?       @db.Text
  status         BookingStatus @default(PENDING)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  sale           Sale          @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  customer       Customer?     @relation(fields: [customer_id], references: [id])
}


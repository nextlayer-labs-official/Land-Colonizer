# HTTP port the Express server listens on
PORT=4000

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# JWT token lifetime
JWT_EXPIRES_IN=7d

# Prisma / MySQL connection string
DATABASE_URL="mysql://user:password@localhost:3306/ams"

# Comma-separated allowed CORS origins (set to your frontend URL in production)
# Leave blank to allow all origins (development only)
CORS_ORIGIN=http://localhost:3000

# Environment (development | production)
NODE_ENV=development
